  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "You're standing in the heart of campus, a wide open brick paved square
    surrounded by a mix of older university buildings and newer glass fronted ones
    like the LSBU Hub. \nThere are long wooden benches dotted around, a bit of greenery
    breaking things up, and usually a handful of students just sitting, passing through,
    or killing time between lectures. It's not a manicured quad, it's a real working
    campus space and that's kind of what makes it feel lived in. \nOn a decent day
    it's actually a pretty good spot to be outside, and you'll find yourself cutting
    through here more times than you can count."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: fa8262f62f0c58549807ecdb3cd379d0, type: 2}
